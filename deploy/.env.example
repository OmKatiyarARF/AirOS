# ----- Keycloak Database -----
# PostgreSQL database name for Keycloak
KC_DB_NAME=keycloak
# PostgreSQL database username
KC_DB_USER=keycloak
# PostgreSQL database password (change this to a strong secret)
KC_DB_PASSWORD=ChangeMeKeycloakDB123#

# ----- Keycloak Admin -----
KC_ADMIN_USER=admin
KC_ADMIN_PASSWORD=ChangeMeKeycloakAdmin123#

# ----- Keycloak Server -----
# Public hostname or IP where Keycloak will be reachable
KC_HOSTNAME=your-server-ip-or-domain

# ----- Keycloak Container / Network -----
KC_CONTAINER_NAME=airos-keycloak
KC_NETWORK_NAME=airos-auth
KC_PORT=8081
